{
  "name": "sbom-monitor",
  "version": "0.1.0",
  "description": "CLI-based software supply chain monitoring tool",
  "license": "MIT",
  "private": true,
  "type": "commonjs",
  "bin": {
    "sbom-monitor": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist && rimraf artifacts && rimraf tmp-*",
    "link": "npm unlink -g sbom-monitor && npm link",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
